# ── Database ──────────────────────────────────────────────────────────────────
# Neon (or any Postgres) connection string — use the "pooled" Neon URL.
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ── Redis ─────────────────────────────────────────────────────────────────────
# Add a Render Redis instance to your service; it injects REDIS_URL automatically.
# With this set, Medusa uses Redis for the event bus, cache, and workflow engine.
# Without it, Medusa falls back to in-process fakes (dev only — not production).
REDIS_URL=redis://default:password@host:6379

# ── Auth secrets ──────────────────────────────────────────────────────────────
# Generate each with:  openssl rand -hex 32
JWT_SECRET=replace-with-a-long-random-string
COOKIE_SECRET=replace-with-a-different-long-random-string

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated allowed origins (no trailing slash, no wildcards).
# STORE_CORS — storefront origins (Vercel URL + localhost for dev)
# ADMIN_CORS — Medusa admin UI origin (same host as the backend on Render)
# AUTH_CORS  — every origin that hits /auth/* (union of store + admin)
STORE_CORS=https://your-storefront.vercel.app,http://localhost:3001
ADMIN_CORS=https://your-backend.onrender.com
AUTH_CORS=https://your-storefront.vercel.app,https://your-backend.onrender.com,http://localhost:3001

# ── Stripe ────────────────────────────────────────────────────────────────────
# Secret key from dashboard.stripe.com → Developers → API keys
STRIPE_API_KEY=sk_live_...
# Signing secret from Stripe → Developers → Webhooks → your endpoint
# Leave blank until the webhook is configured.
STRIPE_WEBHOOK_SECRET=

# ── Email (Resend) ────────────────────────────────────────────────────────────
# API key from resend.com → API Keys
RESEND_API_KEY=re_...
# Verified sender address — must use a domain you've verified in Resend
RESEND_FROM=EBMX Electric Dirtbikes <orders@surronebike.org>
# Storefront base URL — used in email links (no trailing slash)
STOREFRONT_URL=https://electricdirtbike.com.au

# ── Worker mode ───────────────────────────────────────────────────────────────
# "shared" = HTTP + async jobs in one process (correct for a single Render dyno).
# "server" / "worker" = split across two dynos (advanced, costs extra).
MEDUSA_WORKER_MODE=shared

# ── Admin credentials (one-off management scripts only — not runtime) ─────────
MEDUSA_ADMIN_EMAIL=admin@ebmx.com.au
MEDUSA_ADMIN_PASSWORD=REPLACE_WITH_YOUR_PASSWORD
